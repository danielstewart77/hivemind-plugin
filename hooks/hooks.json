{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude-config/hooks/session_start_identity.sh ] && bash ~/.claude-config/hooks/session_start_identity.sh || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude-config/hooks/soul_nudge.sh ] && bash ~/.claude-config/hooks/soul_nudge.sh || true"
          }
        ]
      }
    ]
  }
}
